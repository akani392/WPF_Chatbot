<Window x:Class="WPF_Chatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Chatbot"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid
        
        
        
        Background="#FF000000"
        
        >
        <!-- start of parent grid-->

        <!-- start of chat logo -->
        <Grid
            x:Name="logo_grid"
            Visibility="Visible"
            >

            <!-- start of logo grid-->

            <!-- show logo-->
            <Image 
                Source="/logo.jpg"
                Height="250"
                Width="350"
                Margin="0,0,0,165"
                />

            <!-- button to start ai-->
            <Button
                Height="50"
                Width="200"
                Margin="0,200,0,0"
                Content ="Start Chatbot"
                Click ="start_Chatbot"
                Background="#FF2196F3"
                BorderBrush="Black"
                BorderThickness="5"
                />




        </Grid>
        <!-- end of chat logo -->

        <!-- username grid to prompt user -->
        <Grid 
            x:Name="username_grid" 
            Visibility="Hidden"
            >

            <!-- start of username grid -->

            <!-- show logo at top of screen-->
            <Image
                Source="/logo.jpg"
                Height="100"
                Width="150"
                Margin="0,0,650,320"
                />

            <!-- textbox for username -->
            <TextBox
                x:Name="user_name"
                Height="50"
                Width="400"
                KeyDown="user_name_KeyDown"
                />

            <!-- textblock to show errors (needed for backend code) -->
            <TextBlock 
                x:Name="error_text" 
                Foreground="Red" 
                HorizontalAlignment="Center" 
                Margin="0,70,0,0" 
                Visibility="Collapsed"
                />

            <!-- button to submit username -->
            <Button 
                x:Name="submit_username"
                Height="50"
                Width="200"
                Margin="0,120,0,0"
                Content="Submit user name"
                Click="submit_names"
                Background="#FF2196F3" 
                Foreground="White"
                BorderThickness="1"
                BorderBrush="White"
                
                />

            <!-- end of username grid-->
        </Grid>

        <!-- chats grid -->
        <Grid 
            x:Name="chats_grid"
            Visibility="Hidden"
            >

            <!-- start of chats grid -->

            <!-- show logo at top of screen-->
            <Image
                Source="/logo.jpg"
                Height="100"
                Width="150"
                Margin="0,0,650,320"
                />

            <!-- list to view added chat -->
            <RichTextBox 
                x:Name="chat_rtb"
                Height="200"
                Width="500"
                Margin="0,0,0,160"
                Background="#FF1E1E1E" 
                Foreground="White"
                BorderBrush="#FF2196F3"
                BorderThickness="1"
                VerticalScrollBarVisibility="Auto"
                IsReadOnly="True"
                />  

            <!-- Textbox to enter questions-->
            <TextBox 
                x:Name="questions_textbox"
                Height="50"
                Width="400"
                Margin="0,300,100,0"
                KeyDown="questions_textbox_KeyDown"
                />

            <Button 
                Height="40"
                Width="140"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="500,0,0,20"
                Content="Send"
                Click="send_question"
                Background="#FF2196F3" 
                Foreground="White"
                BorderThickness="1"
                BorderBrush="White"
                />

        </Grid>
        <!-- end of username grid-->


    </Grid>
    <!-- end of parent grid-->
</Window>